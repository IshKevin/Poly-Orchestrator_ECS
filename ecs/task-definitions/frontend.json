{
  "family": "shopnow-dev-frontend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/shopnow-dev-ecs-task-execution",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/shopnow-dev-ecs-task",
  "containerDefinitions": [
    {
      "name": "frontend",
      "image": "ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/shopnow-dev-frontend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "PORT",        "value": "3000" },
        { "name": "BACKEND_URL", "value": "http://backend.shopnow.local:5000" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/shopnow-dev/frontend",
          "awslogs-region":        "us-east-1",
          "awslogs-stream-prefix": "frontend"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "node -e \"require('http').get('http://localhost:3000/health', r => process.exit(r.statusCode===200?0:1))\""
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 15
      }
    }
  ],
  "tags": [
    { "key": "Project",     "value": "shopnow" },
    { "key": "Environment", "value": "dev" },
    { "key": "ManagedBy",   "value": "Terraform" }
  ]
}
